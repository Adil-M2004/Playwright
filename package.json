{
  "name": "cucumber-playwright",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "cucumberWithTS": "cucumber-js src/test/features/*.feature --require-module ts-node/register --require src/test/step-definitions/**/**/*.ts --require src/test/utils/cucumber-timeout.ts -f json:./reports/report.json --tags @selfDeletion",
    "precucumber": "rimraf reports && mkdir reports",
    "cucumber": "npx cucumber-js && ts-node ./src/index.ts",
    "postcucumber": "node ./src/scripts/uploadToXray.js",
    "test:xray": "npm run cucumber --",
    "posttest:xray": "npm run upload-xray"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@cucumber/cucumber": "^12.7.0",
    "@faker-js/faker": "^10.4.0",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "axios": "^1.15.2",
    "playwright-bdd": "^8.5.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@colors/colors": "^1.6.0",
    "dotenv": "^17.4.2",
    "winston": "^3.19.0"
  }
}
